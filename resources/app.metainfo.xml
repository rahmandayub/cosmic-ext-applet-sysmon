<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.github.rahmandayub.Sysmon</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MPL-2.0</project_license>
  <name>Cosmic Sysmon</name>
  <summary>Monitor CPU, RAM, GPU and network speeds from the COSMIC panel</summary>
  <description>
    <p>
      A compact COSMIC panel applet that displays real-time CPU usage, RAM
      consumption, GPU utilization / VRAM / temperature, and download / upload
      network throughput. Click the panel line to open a checklist that lets you
      toggle each metric and pick the network interface to monitor.
    </p>
  </description>
  <icon type="remote" width="64" height="64" scale="1">
    https://github.com/rahmandayub/cosmic-ext-applet-sysmon/raw/main/resources/icon.svg
  </icon>
  <url type="vcs-browser">https://github.com/rahmandayub/cosmic-ext-applet-sysmon</url>
  <launchable type="desktop-id">com.github.rahmandayub.Sysmon.desktop</launchable>
  <provides>
    <id>com.system76.CosmicApplet</id>
    <binaries>
      <binary>cosmic-ext-applet-sysmon</binary>
    </binaries>
  </provides>
  <requires>
    <display_length compare="ge">360</display_length>
  </requires>
  <supports>
    <control>keyboard</control>
    <control>pointing</control>
    <control>touch</control>
  </supports>
  <categories>
    <category>COSMIC</category>
  </categories>
  <keywords>
    <keyword>COSMIC</keyword>
    <keyword>system</keyword>
    <keyword>monitor</keyword>
    <keyword>cpu</keyword>
    <keyword>gpu</keyword>
    <keyword>ram</keyword>
    <keyword>network</keyword>
  </keywords>
  <content_rating type="oars-1.1" />
</component>
